{
  "name": "shell",
  "displayName": "Shell",
  "version": "0.1.0",
  "description": "Secure remote terminal via tmux",
  "capabilities": ["shell:connect"],
  "packages": {
    "server": "@lamalibre/shell-server",
    "agent": "@lamalibre/shell-agent"
  },
  "panel": {
    "pages": [
      { "path": "agents", "title": "Agents", "icon": "users" },
      { "path": "policies", "title": "Policies", "icon": "shield" },
      { "path": "sessions", "title": "Sessions", "icon": "terminal" },
      { "path": "recordings", "title": "Recordings", "icon": "video" },
      { "path": "settings", "title": "Settings", "icon": "settings" }
    ]
  },
  "config": {}
}
